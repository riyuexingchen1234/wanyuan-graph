  <mxGeometry x="995" y="995" width="60" height="20" as="geometry" />
</mxCell>


<mxCell id="fishtail_note" value="鱼尾效应：θ=π/2 或 3π/2（y=0正上正下）时&lt;br&gt;|sinθ|=1 → depth最大 → 窜得最远&lt;br&gt;θ=0 或 π（y=0左右两侧）时&lt;br&gt;|sinθ|=0 → depth最小 → 紧贴主链" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e0;strokeColor=#d6b656;fontSize=10;fontColor=#886;" parent="1" vertex="1">
  <mxGeometry x="600" y="1080" width="260" height="80" as="geometry" />
</mxCell>


<mxCell id="p3_title" value="③ 坐标计算公式（相机局部坐标系 → 世界坐标）" style="text;html=1;fontSize=16;fontStyle=1;fontColor=#1a3a6a;align=left;" parent="1" vertex="1">
  <mxGeometry x="1210" y="20" width="460" height="30" as="geometry" />
</mxCell>

<mxCell id="formula_box" value="" style="rounded=1;fillColor=#f8faff;strokeColor=#6c8ebf;" parent="1" vertex="1">
  <mxGeometry x="1120" y="60" width="460" height="420" as="geometry" />
</mxCell>

<mxCell id="f1" value="&lt;b&gt;Step 1: 构建相机局部基向量&lt;/b&gt;&lt;br&gt;forward = camera.getWorldDirection()  // 看向 -Z&lt;br&gt;up = camera.up  // 世界上方向&lt;br&gt;right = forward × up  // 右方向(叉积)&lt;br&gt;back = -forward  // 远离相机方向" style="text;html=1;fontSize=11;fontColor=#1a3a6a;align=left;whiteSpace=wrap;" parent="1" vertex="1">
  <mxGeometry x="1140" y="1750" width="420" height="90" as="geometry" />
</mxCell>

<mxCell id="f2" value="&lt;b&gt;Step 2: θ角分配（不对称 m/n）&lt;/b&gt;&lt;br&gt;上游 m 个：θ_i = π · (i+1)/(m+1)，i=0..m-1&lt;br&gt;  → 均匀分布在 (0, π) 区间，y&gt;0&lt;br&gt;下游 n 个：θ_j = π + π·(j+1)/(n+1)，j=0..n-1&lt;br&gt;  → 均匀分布在 (π, 2π) 区间，y&lt;0" style="text;html=1;fontSize=11;fontColor=#1a3a6a;align=left;whiteSpace=wrap;" parent="1" vertex="1">
  <mxGeometry x="1140" y="1610" width="420" height="80" as="geometry" />
</mxCell>

<mxCell id="f3" value="&lt;b&gt;Step 3: 尾焰锥体计算（每个支链节点）&lt;/b&gt;&lt;br&gt;depth = D_min + (D_max - D_min) · |sinθ|&lt;br&gt;r = depth · tan(α)  // 环半径&lt;br&gt;offset_local =&lt;br&gt;  right · r·cosθ  // 水平分量&lt;br&gt;+ up · r·sinθ     // 垂直分量&lt;br&gt;+ back · depth   // 深度（远离相机）" style="text;html=1;fontSize=11;fontColor=#1a3a6a;align=left;whiteSpace=wrap;" parent="1" vertex="1">
  <mxGeometry x="1140" y="1430" width="420" height="110" as="geometry" />
</mxCell>

<mxCell id="f4" value="&lt;b&gt;Step 4: 世界坐标&lt;/b&gt;&lt;br&gt;world = parent_world + offset_local&lt;br&gt;&lt;br&gt;&lt;b&gt;主链节点：&lt;/b&gt;&lt;br&gt;offset = right · (i-centerIdx)·d + back · 10&lt;br&gt;&lt;br&gt;&lt;b&gt;Parent 节点：&lt;/b&gt;&lt;br&gt;offset = up · 10 + back · 10" style="text;html=1;fontSize=11;fontColor=#1a3a6a;align=left;whiteSpace=wrap;" parent="1" vertex="1">
  <mxGeometry x="1140" y="995" width="420" height="100" as="geometry" />
</mxCell>


<mxCell id="reclass_title" value="焦点重分类规则（任意节点都可成为焦点 F）" style="text;html=1;fontSize=15;fontStyle=1;fontColor=#1a3a6a;align=left;" parent="1" vertex="1">
  <mxGeometry x="40" y="520" width="400" height="25" as="geometry" />
</mxCell>

<mxCell id="reclass_frame" value="" style="rounded=1;fillColor=#fff8e8;strokeColor=#d6b656;" parent="1" vertex="1">
  <mxGeometry x="40" y="550" width="1540" height="280" as="geometry" />
</mxCell>


<mxCell id="ftype_industry" value="点击&lt;b&gt;产业节点&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffb347;strokeColor=#e69500;fontColor=#000;fontSize=12;fontStyle=1;" parent="1" vertex="1">
  <mxGeometry x="60" y="2064" width="180" height="40" as="geometry" />
</mxCell>
<mxCell id="ftype_industry_desc" value="· 该节点 = P（parent位）&lt;br&gt;· 主链 = sibling双向链，居中节点 = 中心主链 b3&lt;br&gt;· 初始视图" style="text;html=1;fontSize=11;fontColor=#864;align=left;whiteSpace=wrap;" parent="1" vertex="1">
  <mxGeometry x="60" y="1746" width="220" height="60" as="geometry" />
</mxCell>

<mxCell id="ftype_main" value="点击&lt;b&gt;主链节点&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#5cc8ff;strokeColor=#2288cc;fontColor=#000;fontSize=12;fontStyle=1;" parent="1" vertex="1">
  <mxGeometry x="340" y="1802" width="180" height="40" as="geometry" />
</mxCell>
<mxCell id="ftype_main_desc" value="· 该节点 = F（焦点居中）&lt;br&gt;· P = 沿 parent 边向上找到的祖先产业节点&lt;br&gt;· 主链 = 从F沿 sibling 边双向BFS延伸&lt;br&gt;· F 的child节点→新主链F的尾焰" style="text;html=1;fontSize=11;fontColor=#146;align=left;whiteSpace=wrap;" parent="1" vertex="1">
  <mxGeometry x="300" y="1990" width="260" height="80" as="geometry" />
</mxCell>

<mxCell id="ftype_branch" value="点击&lt;b&gt;支链节点&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#aaeeff;strokeColor=#4488aa;fontColor=#000;fontSize=12;fontStyle=1;" parent="1" vertex="1">
  <mxGeometry x="620" y="1400" width="180" height="40" as="geometry" />
</mxCell>
<mxCell id="ftype_branch_desc" value="· 该节点 = F（焦点居中）&lt;br&gt;· P = 该节点的直接父主链节点（放parent位上方）&lt;br&gt;· 主链 = P 的 sibling 链以 F 为中心重构&lt;br&gt;  （F 替代 P 的居中位置，P 移到 parent 位）&lt;br&gt;· 其余支链：归属于各自主链节点的尾焰" style="text;html=1;fontSize=11;fontColor=#146;align=left;whiteSpace=wrap;" parent="1" vertex="1">
  <mxGeometry x="580" y="1230" width="280" height="100" as="geometry" />
</mxCell>


<mxCell id="edge_types_title" value="&lt;b&gt;边类型（必须预先标记）&lt;/b&gt;" style="text;html=1;fontSize=12;fontStyle=1;fontColor=#1a3a6a;" parent="1" vertex="1">
  <mxGeometry x="900" y="1430" width="200" height="25" as="geometry" />
</mxCell>
<mxCell id="edge_p" value="↑ parent：&lt;br&gt;  产业→主链，主链→支链的层级归属" style="text;html=1;fontSize=11;fontColor=#c60;align=left;whiteSpace=wrap;" parent="1" vertex="1">
  <mxGeometry x="900" y="2030" width="300" height="40" as="geometry" />
</mxCell>
<mxCell id="edge_s" value="↔ sibling：&lt;br&gt;  主链节点之间的横向关系（b0-b1-b2...）" style="text;html=1;fontSize=11;fontColor=#2288cc;align=left;whiteSpace=wrap;" parent="1" vertex="1">
  <mxGeometry x="900" y="1320" width="300" height="40" as="geometry" />
</mxCell>
<mxCell id="edge_c" value="↓ child + direction：&lt;br&gt;  主链→支链，标注 upstream/downstream" style="text;html=1;fontSize=11;fontColor=#282;align=left;whiteSpace=wrap;" parent="1" vertex="1">
  <mxGeometry x="900" y="1380" width="300" height="40" as="geometry" />
</mxCell>


<mxCell id="bg_title" value="&lt;b&gt;隔跳节点（≥2跳）= 背景节点&lt;/b&gt;" style="text;html=1;fontSize=12;fontStyle=1;fontColor=#555;" parent="1" vertex="1">
  <mxGeometry x="1230" y="1380" width="320" height="25" as="geometry" />
</mxCell>
<mxCell id="bg_desc" value="· 2跳节点：放到 LAYOUT.bgDistance (≈120) 处环形排列，opacity≈0.15&lt;br&gt;· 3跳及以外：极远 (≈300)，简化为固定小点点（Points材质 sizeAttenuation=false）&lt;br&gt;· LOD策略：相机靠近时渐进加载细节，远离时降级为点&lt;br&gt;· 连线：opacity≈0.05，几乎不可见但保留结构&lt;br&gt;· 性能：远处使用 InstancedMesh 或 Points 批量渲染" style="text;html=1;fontSize=11;fontColor=#555;align=left;whiteSpace=wrap;" parent="1" vertex="1">
  <mxGeometry x="1230" y="1165" width="340" height="110" as="geometry" />
</mxCell>


<mxCell id="algo_title" value="&lt;b&gt;通用布局算法（任意焦点）&lt;/b&gt;" style="text;html=1;fontSize=12;fontStyle=1;fontColor=#1a3a6a;" parent="1" vertex="1">
  <mxGeometry x="60" y="1956" width="300" height="22" as="geometry" />
</mxCell>
<mxCell id="algo_steps" value="① 确定F和P → ② 沿sibling边双向BFS收集主链 → ③ 确定F居中index → ④ 以点击瞬间camera基向量计算每个主链/parent坐标 → ⑤ 遍历主链节点的child边，分配θ并计算尾焰坐标 → ⑥ BFS收集≥2跳节点，按距离降级为背景 → ⑦ 启动动画（相机动画+节点lerp+支链弹性）" style="text;html=1;fontSize=11;fontColor=#333;align=left;whiteSpace=wrap;" parent="1" vertex="1">
  <mxGeometry x="60" y="2140" width="1500" height="50" as="geometry" />
</mxCell>


<mxCell id="cam_rules_title" value="&lt;b&gt;相机交互规则&lt;/b&gt;" style="text;html=1;fontSize=12;fontStyle=1;fontColor=#1a3a6a;" parent="1" vertex="1">
  <mxGeometry x="60" y="1562" width="200" height="22" as="geometry" />
</mxCell>
<mxCell id="cam_rules" value="布局瞬间：以点击时的camera朝向计算right/up/back基向量 → 节点世界坐标固定（非billboard） → 用户自由旋转OrbitControls侧面可见3D锥形 → 再点当前视图的祖先节点：仅TWEEN相机回正对位（不重排）→ 点其他节点：重新走①~⑦布局+相机飞行" style="text;html=1;fontSize=11;fontColor=#333;align=left;whiteSpace=wrap;" parent="1" vertex="1">
  <mxGeometry x="60" y="900" width="1500" height="25" as="geometry" />
</mxCell>

