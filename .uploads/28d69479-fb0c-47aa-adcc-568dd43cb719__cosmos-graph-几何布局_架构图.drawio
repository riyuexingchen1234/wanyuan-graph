  <mxGeometry x="940" y="1168" width="70" height="30" as="geometry" />
</mxCell>


<mxCell id="dmin_label" value="D_min (近)&lt;br&gt;3~5" style="text;html=1;fontSize=9;fontColor=#2288cc;" parent="1" vertex="1">
  <mxGeometry x="940" y="1068" width="50" height="30" as="geometry" />
</mxCell>
