{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "万源图谱数据模型",
  "description": "多关系类型产业链图谱数据模型。节点是唯一实体，不绑定坐标系；关系有方向、有类型，每种类型构成一条独立链路。",
  "type": "object",
  "required": ["nodes", "edges", "chain_types"],
  "properties": {
    "nodes": {
      "type": "array",
      "items": { "$ref": "#/definitions/Node" }
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/definitions/Edge" }
    },
    "chain_types": {
      "type": "array",
      "items": { "$ref": "#/definitions/ChainType" },
      "description": "关系类型配置，定义可用的视角（链路类型）"
    }
  },
  "definitions": {
    "Node": {
      "type": "object",
      "required": ["id", "name", "type", "industry_tags"],
      "properties": {
        "id": {
          "type": "string",
          "description": "唯一标识，slug 格式，如 injection-molding-machine",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "name": {
          "type": "string",
          "description": "显示名称，如 注塑机"
        },
        "aliases": {
          "type": "array",
          "items": { "type": "string" },
          "description": "别名，用于搜索匹配，如 [\"注塑成型机\", \"注射成型机\"]"
        },
        "type": {
          "type": "string",
          "enum": ["industry", "material", "product", "equipment", "consumable", "service", "endpoint"],
          "description": "节点类型"
        },
        "description": {
          "type": "string",
          "description": "简要描述"
        },
        "industry_tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "关联行业标签，如 [\"塑料\", \"包装\"]。用于跨行业交叉检测"
        },
        "metadata": {
          "type": "object",
          "description": "扩展字段，未来使用",
          "additionalProperties": true
        }
      }
    },
    "Edge": {
      "type": "object",
      "required": ["id", "source", "target", "relation_type", "verification_status", "source_type"],
      "properties": {
        "id": {
          "type": "string",
          "description": "唯一标识"
        },
        "source": {
          "type": "string",
          "description": "上游节点 ID"
        },
        "target": {
          "type": "string",
          "description": "下游节点 ID"
        },
        "relation_type": {
          "type": "string",
          "description": "关系类型，决定这条边属于哪条链路。值必须对应 chain_types 中的 type"
        },
        "verification_status": {
          "type": "string",
          "enum": ["proposed", "verified"],
          "description": "验证状态。proposed = 有依据但未验证，verified = 已验证"
        },
        "source_type": {
          "type": "string",
          "enum": ["ai_generated", "manual_entry", "third_party_import", "user_submitted", "field_research"],
          "description": "数据来源类型"
        },
        "evidence": {
          "type": "string",
          "description": "推理依据或来源说明。AI 生成数据必须附带推理过程"
        },
        "source_url": {
          "type": "string",
          "description": "原始来源链接（如有）"
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "创建时间"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time",
          "description": "最后更新时间"
        },
        "verified_at": {
          "type": ["string", "null"],
          "format": "date-time",
          "description": "验证时间，proposed 状态为 null"
        },
        "verified_by": {
          "type": ["string", "null"],
          "description": "验证人，proposed 状态为 null"
        }
      }
    },
    "ChainType": {
      "type": "object",
      "required": ["type", "label", "description"],
      "properties": {
        "type": {
          "type": "string",
          "description": "关系类型标识，如 material_supply"
        },
        "label": {
          "type": "string",
          "description": "显示名称，如 原料链"
        },
        "description": {
          "type": "string",
          "description": "这条链路代表什么，如 原料如何流入"
        },
        "color": {
          "type": "string",
          "description": "可视化颜色（hex），如 #00B42A"
        }
      }
    }
  }
}
